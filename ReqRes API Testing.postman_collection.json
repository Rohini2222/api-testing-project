    {
      "name": "Create User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "pm.test(\"Name matched\", function () {\r",
              "    let jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.name).to.eql(\"Rohini\");\r",
              "});\r",
              "\r",
              "pm.test(\"Job matched\", function () {\r",
              "    let jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.job).to.eql(\"QA Engineer\");\r",
              "});\r",
              "\r",
              "pm.test(\"ID is generated\", function () {\r",
              "   let jsonData= pm.response.json();\r",
              "   pm.expect(jsonData.id).to.exist;\r",
              "\r",
              "});\r",
              "let jsonData = pm.response.json();\r",
              "\r",
              "pm.environment.set(\"created_user_id\", jsonData.id);\r",
              "\r",
              "console.log(\"Created User ID: \" + jsonData.id);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "x-api-key",
            "value": "free_user_3ECWsduZ83dpt9TIkeErXELCVqb",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"name\":\"Rohini\",\r\n    \"job\":\"QA Engineer\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/users",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "users"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Update User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Updated name matched\", function () {\r",
              "    let jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.name).to.eql(\"Rohini Updated\");\r",
              "});\r",
              "\r",
              "pm.test(\"Updated job matched\", function () {\r",
              "    let jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.job).to.eql(\"Senior QA Engineer\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
